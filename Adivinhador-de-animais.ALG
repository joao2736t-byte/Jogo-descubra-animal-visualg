algoritmo "adivinhador_animais"
// Disciplina   : [Linguagem e LÛgica de ProgramaÁ„o] 
// Professor   : Antonio Carlos Nicolodi 
// projeto: Adivinhador de Animais
var
   opcaoMenu, x, y: inteiro
   r1, r2, r3: caractere
   r4, r5, r6, r7: caractere
   animal: caractere
   acertou: logico

// v·lida entrada sÛ de S ou N
procedimento LerResposta(mensagem: caractere; var resp: caractere)
inicio
   repita
      escreva(mensagem, " [S/N]: ")
      leia(resp)
      resp <- maiusc(resp)
      se (resp <> "S") e (resp <> "N") entao
         escreval("  >> Digite apenas S (Sim) ou N (N„o).")
      fimse
   ate (resp = "S") ou (resp = "N")
fimprocedimento

// cabeÁalho
procedimento ExibirCabecalho()
inicio
   escreval("================================================")
   escreval("     ADIVINHADOR DE ANIMAIS - VISUALG          ")
   escreval("    Estou pensando no seu animal...            ")
   escreval("================================================")
   escreval("")
fimprocedimento

// menu principal
procedimento ExibirMenu()
inicio
   escreval("------------------------------------------------")
   escreval("                 MENU PRINCIPAL                ")
   escreval("------------------------------------------------")
   escreval("  1 - Jogar")
   escreval("  2 - Ver InstruÁıes")
   escreval("  3 - Sair")
   escreval("------------------------------------------------")
   escreva("  Escolha uma opÁ„o: ")
   leia(opcaoMenu)
fimprocedimento

// instruÁıes
procedimento ExibirInstrucoes()
inicio
   escreval("")
   escreval("================================================")
   escreval("               COMO JOGAR                      ")
   escreval("================================================")
   escreval(" 1. Pense em um animal.")
   escreval("")
   escreval(" 2. Responda cada pergunta com:")
   escreval("    S = Sim   |   N = N„o")
   escreval("")
   escreval(" 3. O programa tentara adivinhar")
   escreval("    seu animal no final!")
   escreval("")
   escreval(" Animais disponiveis (28 especies):")
   escreval("  ¡guia, Alce, Aranha, Baleia,")
   escreval("  Cachorro, Camelo, Castor, Cavalo,")
   escreval("  Cobra, Coelho, Elefante, Escorpi„o,")
   escreval("  Gaivota, Gato, Golfinho, JacarÈ,")
   escreval("  Le„o, Lobo, Macaco, Morcego,")
   escreval("  Peixe, Rinoceronte, Sapo, Tigre,")
   escreval("  Tubar„o, Urso, Vaca, Veado")
   escreval("================================================")
   escreval("")
fimprocedimento

