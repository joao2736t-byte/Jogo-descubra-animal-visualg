// gerenciador de exibiÁ„o de arte
procedimento ExibirArte(a: caractere)
inicio
   escreval("")
   escreval("------------------------------------------------")

   se a = "Aguia" entao
      Arte_Aguia()
   fimse
   se a = "Gaivota" entao
      Arte_Gaivota()
   fimse
   se a = "Jacare" entao
      Arte_Jacare()
   fimse
   se a = "Morcego" entao
      Arte_Morcego()
   fimse
   se a = "Urso" entao
      Arte_Urso()
   fimse
   se a = "Castor" entao
      Arte_Castor()
   fimse
   se a = "Camelo" entao
      Arte_Camelo()
   fimse
   se a = "Gato" entao
      Arte_Gato()
   fimse
   se a = "Vaca" entao
      Arte_Vaca()
   fimse
   se a = "Veado" entao
      Arte_Veado()
   fimse
   se a = "Cachorro" entao
      Arte_Cachorro()
   fimse
   se a = "Golfinho" entao
      Arte_Golfinho()
   fimse
   se a = "Elefante" entao
      Arte_Elefante()
   fimse
   se a = "Peixe" entao
      Arte_Peixe()
   fimse
   se a = "Sapo" entao
      Arte_Sapo()
   fimse
   se a = "Cavalo" entao
      Arte_Cavalo()
   fimse
   se a = "Macaco" entao
      Arte_Macaco()
   fimse
   se a = "Alce" entao
      Arte_Alce()
   fimse
   se a = "Coelho" entao
      Arte_Coelho()
   fimse
   se a = "Rinoceronte" entao
      Arte_Rinoceronte()
   fimse
   se a = "Escorpiao" entao
      Arte_Escorpiao()
   fimse
   se a = "Aranha" entao
      Arte_Aranha()
   fimse
   se a = "Lobo" entao
      Arte_Lobo()
   fimse
   se a = "Leao" entao
      Arte_Leao()
   fimse
   se a = "Tigre" entao
      Arte_Tigre()
   fimse
   se a = "Baleia" entao
      Arte_Baleia()
   fimse
   se a = "Tubarao" entao
      Arte_Tubarao()
   fimse
   se a = "Cobra" entao
      Arte_Cobra()
   fimse

   escreval("------------------------------------------------")
   escreval("")
fimprocedimento

// lÛgica do jogo
procedimento Jogar()
inicio
   acertou <- falso
   animal  <- ""

   escreval("")
   escreval("================================================")
   escreval("  Pense em um animal...")
   escreval("  Responderei com perguntas de Sim ou N„o!")
   escreval("================================================")
   escreval("")

   LerResposta("1) O animal È VERTEBRADO (tem espinha dorsal)?", r1)

   se r1 = "S" entao

      LerResposta("2) … um MAMÕFERO (amamenta os filhotes)?", r2)

      se r2 = "S" entao

         LerResposta("3) Esse mamÌfero e DOM…STICO (vive com humanos)?", r3)

         se r3 = "S" entao
            LerResposta("4) Esse animal late ou rosna?", r4)
            se r4 = "S" entao
               animal <- "Cachorro"
            senao
               LerResposta("4) Esse animal mia e retrai as garras?", r4)
               se r4 = "S" entao
                  animal <- "Gato"
               senao
                  LerResposta("5) Esse animal È grande, da leite e faz 'muu'?", r5)
                  se r5 = "S" entao
                     animal <- "Vaca"
                  senao
                     LerResposta ("5) Esse animal galopa e relicha?", r5)
                     se r5 = "S" entao
                        animal <- "Cavalo"
                     senao
                        animal <- "Coelho"
                     fimse
                  fimse
               fimse
            fimse

         senao
            LerResposta("4) Esse animal vive em deserto/savana?", r4)

            se r4 = "S" entao
               LerResposta("5) Esse animal tem corcova nas costas?", r5)
               se r5 = "S" entao
                  animal <- "Camelo"
               senao
                  LerResposta("6) Esse animal È um FELINO com juba?", r6)
                  se r6 = "S" entao
                     animal <- "Leao"
                  fimse
               fimse

            senao
               LerResposta("5) Esse animal vive NA ¡GUA ou perto dela?", r5)

               se r5 = "S" entao
                  LerResposta("6) … um mamifero marinho que respira ar?", r6)
                  se r6 = "S" entao
                     LerResposta("7) Esse animal È MUITO GRANDE (maior que um carro)?", r7)
                     se r7 = "S" entao
                        animal <- "Baleia"
                     senao
                        animal <- "Golfinho"
                     fimse
                  senao
                     animal <- "Castor"
                  fimse
               senao
                  LerResposta("6) Esse animal VOA e tem asas?", r6)
                  se r6 = "S" entao
                     animal <- "Morcego"
                  senao
                     LerResposta("7) Esse animal tem CHIFRES grandes como galhos de arvore?", r7)
                     se r7 = "S" entao
                        LerResposta("7) Os chifres s„o achatados e muito largos?", r7)
                        se r7 = "S" entao
                           animal <- "Alce"
                        senao
                           animal <- "Veado"
                        fimse
                     senao
                        LerResposta("7) Esse animal tem uma tromba longa?", r7)
                        se r7 = "S" entao
                           animal <- "Elefante"
                        senao
                           LerResposta("7) Esse animal È um FELINO e tem pelagem listrada?" , r7)
                           se r7 = "S" entao
                              animal <- "Tigre"
                           senao
                              LerResposta("7) Esse animal tem um GRANDE chifre no focinho?", r7)
                              se r7 = "S" entao
                                 animal <- "Rinoceronte"
                              senao
                                 LerResposta("7) Esse animal È peludo, vive em grupo e uiva?", r7)
                                 se r7 = "S" entao
                                    animal <- "Lobo"
                                 senao
                                    LerResposta("7) Esse animal trepa em ·rvores e parece humano?", r7)
                                    se r7 = "S" entao
                                       animal <- "Macaco"
                                    senao
                                       animal <- "Urso"
                                    fimse
                                 fimse
                              fimse
                           fimse
                        fimse
                     fimse
                  fimse
               fimse
            fimse
         fimse

      senao
         LerResposta("3) Esse animal TEM PENAS e voa (ave)?", r3)

         se r3 = "S" entao
            LerResposta("4) Essa ave È uma PREDADORA com garras afiadas?", r4)
            se r4 = "S" entao
               animal <- "Aguia"
            senao
               animal <- "Gaivota"
            fimse

         senao
            LerResposta("4) Esse animal vive SOMENTE NA ¡GUA?", r4)
            se r4 = "S" entao
               LerResposta("5) Esse animal È GRANDE e tem dentes afiados (predador)?", r5)
               se r5 = "S" entao
                  animal <- "Tubarao"
               senao
                  animal <- "Peixe"
               fimse
            senao
               LerResposta("5) Esse animal tem pele LISA e vive na agua e na terra?", r5)
               se r5 = "S" entao
                  animal <- "Sapo"
               senao
                  LerResposta("6) Esse animal e ALONGADO e rasteja pelo chao?", r6)
                  se r6 = "S" entao
                     animal <- "Cobra"
                  senao
                     animal <- "Jacare"
                  fimse
               fimse
            fimse
         fimse
      fimse

   senao
      LerResposta("2) Esse animal tem PATAS articuladas (artropode)?", r2)

      se r2 = "S" entao
         LerResposta("3) Esse animal tem OITO PATAS (aracnideo)?", r3)
         se r3 = "S" entao
            LerResposta("4) Esse animal tem ferr„o na cauda curva?", r4)
            se r4 = "S" entao
               animal <- "Escorpiao"
            senao
               animal <- "Aranha"
            fimse
         fimse
      fimse
   fimse

// resultado final
   escreval("")
   escreval("================================================")
   escreval("  Estou analisando suas respostas...")
   escreval("================================================")
   escreval("")
   escreval("  Eu acho que voce pensou em:")
   escreval("")
   escreval("  >>> ", animal, " <<<")
   escreval("")

   ExibirArte(animal)

   escreval("================================================")

   LerResposta("  Eu acertei?", r7)

   se r7 = "S" entao
      escreval("")
      escreval("  ACERTEI! Nada me escapa!")
      acertou <- verdadeiro
   senao
      escreval("")
      escreval("  Errei desta vez! Voce me venceu.")
      escreval("  Mas voltarei mais forte na proxima!")
   fimse

   escreval("")

   se (acertou = verdadeiro) entao
      x <- x + 1
   senao
      y <- y + 1
   fimse
   escreval ("Minha pontuaÁ„o atual È")
   escreval (">> ", " Acertos: ", x)
   escreval (">> ", " Erros: ", y)
fimprocedimento

// programa principal
inicio
   x <- 0
   y <- 0
   opcaoMenu <- 0

   ExibirCabecalho()

   enquanto opcaoMenu <> 3 faca
      ExibirMenu()

      escolha opcaoMenu
      caso 1
         Jogar()
      caso 2
         ExibirInstrucoes()
      caso 3
         escreval("")
         escreval("  AtÈ a proxima!")
         escreval("")
      outrocaso
         escreval("  >> OpÁ„o inv·lida! Escolha entre 1 e 3.")
      fimescolha
   fimenquanto
fimalgoritmo